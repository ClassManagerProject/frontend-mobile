<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- ──────────────────────────────── Header ─────────────────────────────────── -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Botón atrás -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="@string/back"
            android:scaleType="centerInside"
            android:src="@drawable/ic_arrow_back"
            android:tint="@color/indigo_600"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Título -->
        <TextView
            android:id="@+id/titleHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/task_details"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/slate_900"
            android:textAlignment="center"
            app:layout_constraintLeft_toRightOf="@+id/btnBack"
            app:layout_constraintRight_toLeftOf="@+id/btnMenu"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Botón menú -->
        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="@string/menu"
            android:scaleType="centerInside"
            android:src="@drawable/ic_more_vert"
            android:tint="@color/slate_900"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Separador horizontal -->
    <View
        android:id="@+id/dividerTop"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/slate_100"
        app:layout_constraintTop_toBottomOf="@+id/header" />

    <!-- ──────────────────────────────── Contenido Principal ─────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="100dp"
        app:layout_constraintTop_toBottomOf="@+id/dividerTop"
        app:layout_constraintBottom_toTopOf="@+id/bottomButtonsContainer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Badges: Priority y Status -->
            <LinearLayout
                android:id="@+id/badgesContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Badge Priority -->
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPriority"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:text="HIGH PRIORITY"
                    android:textColor="@color/indigo_700"
                    app:chipBackgroundColor="@color/indigo_100"
                    app:chipCornerRadius="24dp"
                    app:chipIconTint="@color/indigo_700" />

                <!-- Badge Status -->
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IN PROGRESS"
                    android:textColor="@color/indigo_600"
                    app:chipBackgroundColor="@color/indigo_50"
                    app:chipCornerRadius="24dp" />

            </LinearLayout>

            <!-- Título principal -->
            <TextView
                android:id="@+id/taskTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Finalize Project Proposal"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/slate_900"
                android:lineSpacingMultiplier="1.2" />

            <!-- Categoría / Subtítulo -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:text="📋"
                    android:textSize="16sp"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/taskCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="8dp"
                    android:text="Product Design"
                    android:textSize="16sp"
                    android:textColor="@color/indigo_600"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Card Schedule -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/indigo_50">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <!-- Icon -->
                    <FrameLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_icon_circle">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🕐"
                            android:textSize="28sp"
                            android:gravity="center"
                            android:layout_gravity="center" />

                    </FrameLayout>

                    <!-- Content -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginLeft="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/schedule_label"
                            android:textSize="12sp"
                            android:textColor="@color/slate_500"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/taskSchedule"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="10:00 AM - 12:00 PM"
                            android:textSize="16sp"
                            android:textColor="@color/slate_900"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Card Due Date -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white"
                app:cardUseCompatPadding="true"
                app:cardPreventCornerOverlap="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:background="@color/slate_50">

                    <!-- Icon -->
                    <FrameLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_icon_circle">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📅"
                            android:textSize="28sp"
                            android:gravity="center"
                            android:layout_gravity="center" />

                    </FrameLayout>

                    <!-- Content -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginLeft="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/due_date_label"
                            android:textSize="12sp"
                            android:textColor="@color/slate_500"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/taskDueDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Friday, Oct 27"
                            android:textSize="16sp"
                            android:textColor="@color/slate_900"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- SUB-TASKS Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:orientation="vertical">

                <!-- Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/sub_tasks_label"
                        android:textSize="14sp"
                        android:textColor="@color/slate_600"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/subTasksProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2/4 Completed"
                        android:textSize="14sp"
                        android:textColor="@color/indigo_600"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- SubTasks List -->
                <LinearLayout
                    android:id="@+id/subTasksContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />

                <!-- Add SubTask Button -->
                <Button
                    android:id="@+id/btnAddSubTask"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:text="@string/add_sub_task"
                    android:textColor="@color/indigo_600"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="?selectableItemBackground"
                    android:foreground="?selectableItemBackground" />

            </LinearLayout>

            <!-- NOTES Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/notes_label"
                    android:textSize="14sp"
                    android:textColor="@color/slate_600"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <TextView
                    android:id="@+id/taskNotes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Ensure the color palette for the prototype matches the client's brand guidelines. The submission needs to be in PDF format. Don't forget to include the stakeholder interview summaries in the appendix."
                    android:textSize="14sp"
                    android:textColor="@color/slate_700"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ──────────────────────────────── Bottom Buttons ─────────────────────────────── -->
    <LinearLayout
        android:id="@+id/bottomButtonsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/white"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Mark as Completed Button -->
        <Button
            android:id="@+id/btnMarkCompleted"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/mark_completed"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_primary"
            android:stateListAnimator="@null" />

        <!-- Action Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <!-- Edit Button -->
            <Button
                android:id="@+id/btnEdit"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/edit"
                android:textColor="@color/indigo_600"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_outline"
                android:drawableLeft="@drawable/ic_edit"
                android:drawablePadding="8dp"
                android:gravity="center" />

            <!-- Delete Button -->
            <Button
                android:id="@+id/btnDelete"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="@string/delete"
                android:textColor="@color/red_500"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_outline"
                android:drawableLeft="@drawable/ic_delete"
                android:drawablePadding="8dp"
                android:gravity="center" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>


